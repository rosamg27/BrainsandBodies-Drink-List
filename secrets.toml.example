# Kopiere diese Datei lokal nach .streamlit/secrets.toml (mit echten Werten).
# Auf Streamlit Community Cloud trägst du dieselben Werte stattdessen unter
# "Settings" -> "Secrets" der App ein - NICHT als Datei ins Repo committen.

STRIPE_SECRET_KEY = "sk_live_… oder sk_test_…"
APP_URL = "https://deine-app.streamlit.app"
STAFF_PIN = "1234"
PRICE_1 = "price_…"   # Stripe Price ID für den 1er Block
PRICE_5 = "price_…"   # Stripe Price ID für den 5er Block
PRICE_10 = "price_…"  # Stripe Price ID für den 10er Block
